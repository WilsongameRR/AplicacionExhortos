<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Exhortos</title>

    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Ya no necesitas bootstrap-icons -->
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
</head>

<body>

    @* NAVBAR SUPERIOR *@
    <nav class="navbar navbar-dark bg-dark fixed-top">
        <div class="container-fluid">

            <div class="d-flex align-items-center">
                @* BOTÓN MENÚ *@
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#offcanvasNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @* USUARIO *@
                <span class="navbar-brand ms-3 mb-0">
                    @(Context.Session.GetString("Usuario") ?? "Usuario")
                    / TUA @(Context.Session.GetString("NumTua") ?? "--")
                </span>
            </div>

            @* BOTÓN SALIR *@
            <a asp-controller="Login"
                   asp-action="Logout"
                   class="btn btn-outline-light d-flex align-items-center">

                <img src="/Images/Icons/person-walking.svg"
                     width="20"
                     height="20"
                     class="me-2 icon-white" />

                <span>Salir</span>
            </a>

        </div>
    </nav>


    @* MENÚ LATERAL *@
    <div class="offcanvas offcanvas-start bg-dark text-white"
         tabindex="-1"
         id="offcanvasNavbar">

        <div class="offcanvas-header">
            <h5 class="offcanvas-title">Menú</h5>

            <button type="button"
                    class="btn-close btn-close-white"
                    data-bs-dismiss="offcanvas">
            </button>
        </div>

        <div class="offcanvas-body">

            @* LOGO *@
            <div class="d-flex align-items-center mb-3">
                <img src="/Images/LogoTUA.png"
                     style="width:80px;"
                     class="me-3" />

                <div>
                    <h6 class="mb-1">SISTEMA DE EXHORTOS</h6>
                    <small class="text-secondary">
                        Tribunales Unitarios Agrarios
                    </small>
                </div>
            </div>

            <hr class="text-secondary" />

            <ul class="navbar-nav flex-column">

                @* ===== ENVÍA ===== *@
                <li class="nav-item mt-2">
                    <span class="text-secondary small ps-2">ENVÍA</span>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-controller="Exhortos"
                           asp-action="AltaDeExhortos">
                        Alta de Exhortos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-controller="Diligencias"
                           asp-action="AltaDiligencia">
                        Alta de Diligencias
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-controller="ExhortosConsulta"
                           asp-action="ExhortosConsulta">
                        Consulta de Exhortos
                    </a>
                </li>

                @* ===== LÍNEA DIVISORA ===== *@
                <li class="nav-item">
                    <hr class="menu-divider" />
                </li>

                @* ===== RECIBE ===== *@
                <li class="nav-item">
                    <span class="text-secondary small ps-2">RECIBE</span>
                </li>

                @*
    <li class="nav-item">
        <a class="nav-link text-white"
           asp-controller="ExhortosConsulta"
           asp-action="ExhortoSeguimiento">
            Seguimiento de Exhortos
        </a>
    </li>
    *@
            </ul>

        </div>
    </div>

    @* CONTENIDO (CORREGIDO) *@
    <main>
        @RenderBody()
    </main>

    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>