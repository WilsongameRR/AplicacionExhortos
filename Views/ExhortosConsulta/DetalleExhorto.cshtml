@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>DETALLE DEL EXHORTO</h2>
            </div>

            <div class="card">
                <div class="card-body">

                    <h5 class="mb-4">
                        No. Exhorto Enviado:
                    </h5>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Expediente</label>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Oficio</label>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Estatus</label>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Estado</label>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Municipio</label>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Poblado</label>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label class="form-label">TUA Exhortado</label>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Fecha de Acuerdo</label>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Fecha de Envío</label>
                        </div>
                    </div>

                    <table class="table table-bordered table-striped">
                        <thead class="table-success">
                            <tr>
                                <th>Diligencia</th>
                                <th>Destinatario</th>
                                <th>Fecha Diligencia</th>
                                <th>Estatus</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="text-center mt-4">
                        <a asp-controller="ExhortosConsulta"
                               asp-action="ExhortosConsulta"
                               class="btn btn-secondary">
                            Regresar
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>