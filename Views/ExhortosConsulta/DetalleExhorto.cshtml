@model AplicacionExhortos.Models.DetalleExhortoModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    int pageSize = 5;
    int currentPage = 1;

    if (!string.IsNullOrEmpty(Context.Request.Query["page"]))
    {
        int.TryParse(Context.Request.Query["page"], out currentPage);

        if (currentPage <= 0)
        {
            currentPage = 1;
        }
    }

    var totalItems = Model.Diligencias?.Count ?? 0;
    var totalPages = (int)Math.Ceiling((double)totalItems / pageSize);

    if (totalPages == 0)
    {
        totalPages = 1;
    }

    var diligenciasPaginadas = Model.Diligencias?
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList() ?? new List<AplicacionExhortos.Models.DiligenciaModel>();
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>DETALLE DEL EXHORTO</h2>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">

                    <h5 class="mb-4">
                        No. Exhorto Enviado:
                        <span class="fw-bold">@Model.Exhorto.NoExhortoEnviado</span>
                    </h5>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Expediente</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.NoExpediente
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Oficio</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.NoOficio
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Estatus</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.Estatus
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Estado</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.Estado
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Municipio</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.Municipio
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Poblado</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.Poblado
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">TUA Exhortado</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.tuaDestino
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha de Acuerdo</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.FechaAcuerdo
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha de Envío</label>
                            <div class="form-control bg-light">
                                @Model.Exhorto.FechaEnvio
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped">
                            <thead class="table-success">
                                <tr>
                                    <th>Diligencia</th>
                                    <th>Destinatario</th>
                                    <th>Fecha Diligencia</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (diligenciasPaginadas.Any())
                                {
                                    @foreach (var item in diligenciasPaginadas)
                                    {
                                        <tr>
                                            <td>@item.TipoDiligenciaDesc</td>
                                            <td>@item.Destinatario</td>
                                            <td>@item.FechaDiligencia</td>
                                            <td>@item.EstatusDiligencia</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center">Sin diligencias registradas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.Diligencias != null && Model.Diligencias.Any())
                    {
                        <nav aria-label="Page navigation example" class="mt-4">
                            <ul class="pagination justify-content-center">

                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-controller="ExhortosConsulta"
                                           asp-action="DetalleExhorto"
                                           asp-route-id="@Model.Exhorto.ExhortoId"
                                           asp-route-page="@(currentPage - 1)">
                                        Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link"
                                               asp-controller="ExhortosConsulta"
                                               asp-action="DetalleExhorto"
                                               asp-route-id="@Model.Exhorto.ExhortoId"
                                               asp-route-page="@i">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-controller="ExhortosConsulta"
                                           asp-action="DetalleExhorto"
                                           asp-route-id="@Model.Exhorto.ExhortoId"
                                           asp-route-page="@(currentPage + 1)">
                                        Next
                                    </a>
                                </li>

                            </ul>
                        </nav>
                    }

                    <div class="text-center mt-4">
                        <a asp-controller="ExhortosConsulta"
                               asp-action="ExhortosConsulta"
                               class="btn btn-secondary">
                            Regresar
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>