@model AplicacionExhortos.Models.ReiterarExhortoModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <div class="text-center mt-4 mb-4">
                <h2>REITERAR EXHORTO</h2>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger text-center">
                    @TempData["Error"]
                </div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success text-center">
                    @TempData["Success"]
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-body">

                    <form asp-action="ReiterarExhorto" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ExhortoId" />
                        <input type="hidden" asp-for="NumeroEnvios" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">No. Exhorto Exhortante:</label>
                                <div class="form-control bg-light">@Model.NoExhortoEnviado</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Expediente:</label>
                                <div class="form-control bg-light">@Model.NoExpediente</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">No. Oficio:</label>
                                <div class="form-control bg-light">@Model.NoOficio</div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Estado:</label>
                                <div class="form-control bg-light">@Model.Estado</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Municipio:</label>
                                <div class="form-control bg-light">@Model.Municipio</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Poblado:</label>
                                <div class="form-control bg-light">@Model.Poblado</div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">TUA Exhortado:</label>
                                <div class="form-control bg-light">@Model.TuaDestino</div>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="FechaNuevoAcuerdo" class="form-label fw-bold">* Fecha Nuevo Acuerdo:</label>
                                <input asp-for="FechaNuevoAcuerdo" type="date" class="form-control" />
                                <span asp-validation-for="FechaNuevoAcuerdo" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="FechaNuevaAudiencia" class="form-label fw-bold">* Fecha Nueva Audiencia:</label>
                                <input asp-for="FechaNuevaAudiencia" type="date" class="form-control" />
                                <span asp-validation-for="FechaNuevaAudiencia" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Adjuntar documentos</label>
                            <a href="javascript:void(0);" class="ms-2 text-decoration-none fw-bold fs-4">+</a>
                        </div>

                        <div class="text-center mb-3">
                            <h4 class="fw-bold">DILIGENCIAS</h4>
                        </div>

                        <div class="table-responsive mt-2">
                            <table class="table table-bordered table-striped">
                                <thead class="thead-tua">
                                    <tr>
                                        <th>Diligencia</th>
                                        <th>Destinatario</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Diligencias != null && Model.Diligencias.Any())
                                    {
                                        foreach (var d in Model.Diligencias)
                                        {
                                            <tr>
                                                <td>@d.TipoDiligenciaDesc</td>
                                                <td>@d.Destinatario</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center text-muted">
                                                No hay diligencias registradas.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                            <a asp-action="DetalleExhorto"
                                   asp-route-id="@Model.ExhortoId"
                                   class="btn btn-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-primary">
                                Guardar
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}