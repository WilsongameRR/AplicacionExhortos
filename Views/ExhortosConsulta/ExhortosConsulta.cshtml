@model List<AplicacionExhortos.Models.ConsultaExhortos>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>EXHORTOS ENVIADOS</h2>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <input class="form-control" id="txtBuscar" type="text" placeholder="Buscar..." />
                </div>
            </div>

            <table id="tablaSeguimiento" class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Acción</th>
                        <th style="display:none;">ID</th>
                        <th>Exhorto</th>
                        <th>Expediente</th>
                        <th>Estado</th>
                        <th>Municipio</th>
                        <th>Tua Exhortado</th>
                        <th>Fecha de Acuerdo</th>
                        <th>Fecha de Envío</th>
                        <th>Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <a asp-controller="ExhortosConsulta"
                                           asp-action="DetalleExhorto"
                                           asp-route-id="@item.ExhortoId"
                                           title="Ver detalle">
                                        <img src="~/Images/Icons/eye-fill.svg" width="20" alt="Ver" />
                                    </a>
                                </td>

                                <td style="display:none;">@item.ExhortoId</td>
                                <td>@item.NoExhortoEnviado</td>
                                <td>@item.NoExpediente</td>
                                <td>@item.Estado</td>
                                <td>@item.Municipio</td>
                                <td>@item.TuaDestino</td>
                                <td>@(string.IsNullOrWhiteSpace(item.FechaAcuerdo) ? string.Empty : item.FechaAcuerdo.Split(' ')[0])</td>
                                <td>@(string.IsNullOrWhiteSpace(item.FechaEnvio) ? string.Empty : item.FechaEnvio.Split(' ')[0])</td>
                                <td>@item.Estatus</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const tabla = $('#tablaSeguimiento').DataTable({
                pageLength: 10,
                lengthChange: false,
                dom: 'rtip',
                language: {
                    url: '/js/datatables/spanish.json',
                    emptyTable: 'Sin exhortos registrados.',
                    zeroRecords: 'Sin exhortos registrados.'
                }
            });

            $('#txtBuscar').on('keyup', function () {
                tabla.search($(this).val()).draw();
            });
        });
    </script>
}