@model List<AplicacionExhortos.Models.ConsultaExhortos>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>EXHORTOS PENDIENTES DE ENVÍO</h2>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <input class="form-control"
                           id="txtBuscar"
                           type="text"
                           placeholder="Buscar..."
                           aria-label="Buscar exhortos pendientes" />
                </div>
            </div>

            <div class="table-responsive">
                <table id="tablaPendientes" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th class="text-center">Enviar</th>
                            <th style="display:none;">ID</th>
                            <th>No. Exhorto</th>
                            <th>Expediente</th>
                            <th>TUA Exhortado</th>
                            <th>Estatus del Exhorto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <button type="button"
                                                class="btn btn-link text-decoration-none p-0 btnConfirmarDocumento"
                                                title="Agregar documentos"
                                                data-noexhorto="@item.NoExhortoEnviado">

                                            <img src="~/Images/Icons/folder-symlink.svg"
                                                 alt="Adjuntar documentos"
                                                 style="width:22px; height:22px;" />
                                        </button>
                                    </td>

                                    <td style="display:none;">@item.ExhortoId</td>
                                    <td>@item.NoExhortoEnviado</td>
                                    <td>@item.NoExpediente</td>
                                    <td>@item.TuaDestino</td>
                                    <td>@item.Estatus</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<div class="modal fade"
     id="modalConfirmarDocumentos"
     tabindex="-1"
     aria-labelledby="modalConfirmarDocumentosLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header"
                 style="background-color:#E87A45; color:white;">
                <h5 class="modal-title fw-bold"
                    id="modalConfirmarDocumentosLabel">
                    Confirmación
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>
            </div>

            <div class="modal-body text-center fs-6 py-4">
                Continuará con el registro del exhorto,<br />
                ¿Desea adjuntar documentos?
            </div>

            <div class="modal-footer justify-content-center">
                <button type="button"
                        id="btnSiAdjuntarDocumento"
                        class="btn btn-tua px-4">
                    Sí
                </button>

                <button type="button"
                        id="btnNoAdjuntarDocumento"
                        class="btn btn-secondary px-4">
                    No
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const tabla = $('#tablaPendientes').DataTable({
                pageLength: 10,
                lengthChange: false,
                dom: 'rtip',
                language: {
                    url: '/js/datatables/spanish.json',
                    emptyTable: 'Sin exhortos pendientes.',
                    zeroRecords: 'Sin exhortos pendientes.'
                }
            });

            $('#txtBuscar').on('keyup', function () {
                tabla.search($(this).val()).draw();
            });

            let noExhortoSeleccionado = '';

            $(document).on('click', '.btnConfirmarDocumento', function () {
                noExhortoSeleccionado = $(this).data('noexhorto');

                const modal = new bootstrap.Modal(
                    document.getElementById('modalConfirmarDocumentos')
                );

                modal.show();
            });

            $('#btnSiAdjuntarDocumento').on('click', function () {
                if (!noExhortoSeleccionado) {
                    return;
                }

                window.location.href =
                    '/Exhortos/AltaDocumentos?noExhorto=' +
                    encodeURIComponent(noExhortoSeleccionado);
            });

            $('#btnNoAdjuntarDocumento').on('click', function () {
                if (!noExhortoSeleccionado) {
                    return;
                }

                window.location.href =
                    '/Diligencias/AltaDiligencia?noExhorto=' +
                    encodeURIComponent(noExhortoSeleccionado);
            });
        });
    </script>
}