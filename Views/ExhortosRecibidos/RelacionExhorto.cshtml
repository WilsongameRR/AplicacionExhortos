@model AplicacionExhortos.Models.DetalleExhortoModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-11">

            <div class="text-center mt-4 mb-4">
                <h2>RELACIÓN DEL EXHORTO</h2>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">

                    <div class="text-center mb-4">
                        <h4 class="fw-bold">DATOS DEL EXHORTO</h4>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">TUA Exhortante:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.tuaOrigen</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">No. Exhorto Exhortante:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.NoExhortoEnviado</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Expediente:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.NoExpediente</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Oficio:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.NoOficio</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Estado:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.Estado</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Municipio:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.Municipio</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Poblado:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.Poblado</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Documentos:</label>
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm mb-0">
                                    <thead class="table-success">
                                        <tr>
                                            <th>Tipo Documento</th>
                                            <th>Link</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td colspan="2" class="text-center text-muted">Sin documentos</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha de Acuerdo:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.FechaAcuerdo</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha de Audiencia:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.FechaAudiencia</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha de Envío:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.FechaEnvio</div>
                        </div>
                    </div>

                    <div class="text-center mb-4">
                        <h4 class="fw-bold">SEGUIMIENTO</h4>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">No. Exhorto Recibido:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.NoExhortoRecibido</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Fecha de Recepción:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.FechaRecepcion</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">No. Folio:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.Folio</div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Estatus del Exhorto:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.Estatus</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha Acuerdo TUA Exhortado:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.FechaAcuerdoTuaExhortado</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha Turno Actuaría:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.FechaTurnoActuaria</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha de Vencimiento:</label>
                            <div class="form-control bg-light">@Model?.Exhorto?.FechaVencimiento</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Observaciones:</label>
                        <div class="form-control bg-light">@Model?.Exhorto?.Observaciones</div>
                    </div>

                    <div class="text-center mb-3">
                        <h4 class="fw-bold">DILIGENCIAS</h4>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped">
                            <thead class="table-warning">
                                <tr>
                                    <th>Diligencia</th>
                                    <th>Destinatario</th>
                                    <th>Fecha Diligencia</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.Diligencias != null && Model.Diligencias.Any())
                                {
                                    foreach (var item in Model.Diligencias)
                                    {
                                        <tr>
                                            <td>
                                                @item.TipoDiligenciaDesc
                                                @if (!string.IsNullOrWhiteSpace(item.OtraEspecificar))
                                                {
                                                    <span> - @item.OtraEspecificar</span>
                                                }
                                            </td>
                                            <td>@item.Destinatario</td>
                                            <td>@item.FechaDiligencia</td>
                                            <td>@item.EstatusDiligencia</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center">Sin diligencias registradas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="text-center mt-4">
                        <a asp-controller="ExhortosRecibidos"
                               asp-action="ExhortosRecibidos"
                               class="btn btn-secondary">
                            Regresar
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>