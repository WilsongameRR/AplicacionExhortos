@model AplicacionExhortos.Models.DetalleExhortoModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>DETALLE DEL EXHORTO</h2>
            </div>

            @if (Model?.Exhorto == null)
            {
                <div class="alert alert-warning text-center">
                    No se encontró información del exhorto.
                </div>
            }
            else
            {
                <!-- ===================== -->
                <!-- DATOS GENERALES -->
                <!-- ===================== -->
                <div class="card mb-4">
                    <div class="card-header bg-dark text-white">
                        DATOS GENERALES
                    </div>

                    <div class="card-body">

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">No. Exhorto:</label>
                                <div class="form-control bg-light">@Model.Exhorto.NoExhortoEnviado</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Expediente:</label>
                                <div class="form-control bg-light">@Model.Exhorto.NoExpediente</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Oficio:</label>
                                <div class="form-control bg-light">@Model.Exhorto.NoOficio</div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">TUA Origen:</label>
                                <div class="form-control bg-light">@Model.Exhorto.TuaOrigen</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">TUA Destino:</label>
                                <div class="form-control bg-light">@Model.Exhorto.TuaDestino</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Estatus:</label>
                                <div class="form-control bg-light">@Model.Exhorto.Estatus</div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ===================== -->
                <!-- FECHAS -->
                <!-- ===================== -->
                <div class="card mb-4">
                    <div class="card-header bg-secondary text-white">
                        FECHAS
                    </div>

                    <div class="card-body">

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha Acuerdo:</label>
                                <div class="form-control bg-light">@Model.Exhorto.FechaAcuerdo</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha Audiencia:</label>
                                <div class="form-control bg-light">@Model.Exhorto.FechaAudiencia</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha Envío:</label>
                                <div class="form-control bg-light">@Model.Exhorto.FechaEnvio</div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha Recibido:</label>
                                <div class="form-control bg-light">@Model.Exhorto.FechaRecibido</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha Acuerdo TUA Exhortado:</label>
                                <div class="form-control bg-light">@Model.Exhorto.FechaAcuerdoExhortado</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha Turno Actuaría:</label>
                                <div class="form-control bg-light">@Model.Exhorto.FechaTurnoActuaria</div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha Devolución:</label>
                                <div class="form-control bg-light">@Model.Exhorto.FechaDevolucion</div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ===================== -->
                <!-- DILIGENCIAS -->
                <!-- ===================== -->
                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        DILIGENCIAS
                    </div>

                    <div class="card-body">

                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Destinatario</th>
                                    <th>Fecha</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Diligencias != null && Model.Diligencias.Any())
                                {
                                    foreach (var d in Model.Diligencias)
                                    {
                                        <tr>
                                            <td>@d.TipoDiligenciaDesc</td>
                                            <td>@d.Destinatario</td>
                                            <td>@d.FechaDiligencia</td>
                                            <td>@d.EstatusDiligencia</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted">
                                            No hay diligencias registradas.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            }

            <div class="text-center mt-3">
                <a asp-action="ExhortosRecibidos" class="btn btn-secondary">
                    Regresar
                </a>
            </div>

        </div>
    </div>
</div>