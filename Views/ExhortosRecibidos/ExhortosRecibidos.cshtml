@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>EXHORTOS RECIBIDOS</h2>
            </div>


            <div class="row mb-3">
                <div class="col-md-4">
                    <input class="form-control" id="txtBuscar" type="text" placeholder="Buscar..." />
                </div>
            </div>

            <table id="tablaSeguimiento" class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Acción</th>
                        <th style="display:none;">ID</th>
                        <th>No. Exhorto</th>
                        <th>Folio</th>
                        <th>Tua Exhortante</th>
                        <th>Expediente</th>
                        <th>Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="10" class="text-center text-muted">
                            No hay exhortos recibidos para mostrar.
                        </td>
                    </tr>
                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const tabla = $('#tablaSeguimiento').DataTable({
                pageLength: 10,
                lengthChange: false,
                dom: 'rtip',
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.8/i18n/es-ES.json'
                }
            });

            $('#txtBuscar').on('keyup', function () {
                tabla.search($(this).val()).draw();
            });
        });
    </script>
}