@model List<AplicacionExhortos.Models.ConsultaExhortos>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <!-- TÍTULO -->
            <div class="text-center mt-4 mb-4">
                <h2>CONSULTA DE EXHORTOS RECIBIDOS</h2>
            </div>

            <!-- MENSAJE ERROR -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-warning text-center">
                    @TempData["Error"]
                </div>
            }

            <!-- BUSCADOR -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <input class="form-control" id="txtBuscar" type="text" placeholder="Buscar..." />
                </div>
            </div>

            <!-- TABLA SOLO VISUAL -->
            <table id="tablaSeguimiento" class="table table-striped" style="user-select: none;">
                <thead>
                    <tr>
                        <th>Acción</th>
                        <th style="display:none;">ID</th>
                        <th>No. Exhorto</th>
                        <th>Folio</th>
                        <th>TUA Exhortante</th>
                        <th>Expediente</th>
                        <th>Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <a asp-controller="ExhortosRecibidos"
                                           asp-action="DetalleExhorto"
                                           asp-route-id="@item.ExhortoId"
                                           title="Ver detalle">
                                        <img src="~/Images/Icons/eye-fill.svg" width="20" alt="Ver" />
                                    </a>
                                </td>
                                <td style="display:none;">@item.ExhortoId</td>
                                <td>@item.NoExhortoEnviado</td>
                                <td>@item.Folio</td>
                                <td>@item.TuaOrigen</td>
                                <td>@item.NoExpediente</td>
                                <td>@item.Estatus</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            const tabla = $('#tablaSeguimiento').DataTable({
                pageLength: 10,
                lengthChange: false,
                ordering: false, 
                dom: 'rtip',
                language: {
                    url: '/js/datatables/spanish.json',
                    emptyTable: 'No hay exhortos recibidos para mostrar.'
                }
            });

            $('#txtBuscar').on('keyup', function () {
                tabla.search($(this).val()).draw();
            });

        });
    </script>
}