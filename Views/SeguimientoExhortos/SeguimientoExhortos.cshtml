@model List<AplicacionExhortos.Models.ConsultaExhortos>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>SEGUIMIENTO DE EXHORTOS</h2>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <input class="form-control" id="txtBuscarSeguimiento" type="text" placeholder="Buscar..." />
                </div>
            </div>

            <table id="tablaSeguimientoExhortos" class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Acción</th>
                        <th style="display:none;">ID</th>
                        <th>No. Exhorto</th>
                        <th>Expediente</th>
                        <th>TUA Exhortante</th>
                        <th>Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <a asp-controller="SeguimientoExhortos"
                                           asp-action="DetalleSeguimiento"
                                           asp-route-exhortoId="@item.ExhortoId"
                                           title="Editar">
    
                                        <img src="~/Images/Icons/pencil.svg"
                                             width="20"
                                             alt="Editar"
                                             style="cursor:pointer;" />
                                    </a>
                                </td>

                                <td style="display:none;">@item.ExhortoId</td>
                                <td>@item.NoExhortoEnviado</td>
                                <td>@item.NoExpediente</td>
                                <td>@item.TuaOrigen</td>
                                <td>@item.Estatus</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const tabla = $('#tablaSeguimientoExhortos').DataTable({
                pageLength: 10,
                lengthChange: false,
                dom: 'rtip',
                language: {
                    url: '/js/datatables/spanish.json',
                    emptyTable: 'Sin registros de seguimiento.',
                    zeroRecords: 'Sin registros de seguimiento.'
                }
            });

            $('#txtBuscarSeguimiento').on('keyup', function () {
                tabla.search($(this).val()).draw();
            });
        });
    </script>
}