@model AplicacionExhortos.Models.DetalleExhortoModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    int pageSize = 5;
    int currentPage = 1;

    if (!string.IsNullOrEmpty(Context.Request.Query["page"]))
    {
        int.TryParse(Context.Request.Query["page"], out currentPage);

        if (currentPage <= 0)
        {
            currentPage = 1;
        }
    }

    var totalItems = Model?.Diligencias?.Count ?? 0;
    var totalPages = (int)Math.Ceiling((double)totalItems / pageSize);

    if (totalPages == 0)
    {
        totalPages = 1;
    }

    var diligenciasPaginadas = Model?.Diligencias?
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList() ?? new List<AplicacionExhortos.Models.DiligenciaModel>();
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            @if (Model?.Exhorto == null)
            {
                <div class="alert alert-warning text-center">
                    No se encontró información del exhorto.
                </div>
            }
            else
            {
                <input type="hidden" id="noExhortoModal" value="@Model.Exhorto.NoExhortoEnviado" />

                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-4">

                        <!-- DATOS DEL EXHORTO -->
                        <div class="mb-5">
                            <div class="text-center mb-4">
                                <h4 class="fw-bold">DATOS DEL EXHORTO</h4>
                                <hr class="mt-2" />
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6 col-lg-3">
                                    <label class="form-label fw-bold">No. Exhorto Exhortante:</label>
                                    <div class="form-control bg-light">
                                        @Model.Exhorto.NoExhortoEnviado
                                    </div>
                                </div>

                                <div class="col-md-6 col-lg-3">
                                    <label class="form-label fw-bold">TUA Exhortante:</label>
                                    <div class="form-control bg-light">
                                        @Model.Exhorto.TuaOrigen
                                    </div>
                                </div>

                                <div class="col-md-6 col-lg-3">
                                    <label class="form-label fw-bold">Expediente:</label>
                                    <div class="form-control bg-light">
                                        @Model.Exhorto.NoExpediente
                                    </div>
                                </div>

                                <div class="col-md-6 col-lg-3">
                                    <label class="form-label fw-bold">Oficio:</label>
                                    <div class="form-control bg-light">
                                        @Model.Exhorto.NoOficio
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6 col-lg-4">
                                    <label class="form-label fw-bold">Estado:</label>
                                    <div class="form-control bg-light">
                                        @Model.Exhorto.Estado
                                    </div>
                                </div>

                                <div class="col-md-6 col-lg-4">
                                    <label class="form-label fw-bold">Municipio:</label>
                                    <div class="form-control bg-light">
                                        @Model.Exhorto.Municipio
                                    </div>
                                </div>

                                <div class="col-md-12 col-lg-4">
                                    <label class="form-label fw-bold">Poblado:</label>
                                    <div class="form-control bg-light">
                                        @Model.Exhorto.Poblado
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Fecha de Acuerdo:</label>
                                    <div class="form-control bg-light">
                                        @(Model.Exhorto.FechaAcuerdo != null
                                            ? Convert.ToDateTime(Model.Exhorto.FechaAcuerdo).ToString("dd/MM/yyyy")
                                            : "")
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Fecha de Audiencia:</label>
                                    <div class="form-control bg-light">
                                        @(Model.Exhorto.FechaAudiencia != null
                                            ? Convert.ToDateTime(Model.Exhorto.FechaAudiencia).ToString("dd/MM/yyyy")
                                            : "")
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Fecha de Envío:</label>
                                    <div class="form-control bg-light">
                                        @(Model.Exhorto.FechaEnvio != null
                                            ? Convert.ToDateTime(Model.Exhorto.FechaEnvio).ToString("dd/MM/yyyy")
                                            : "")
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                    <label class="form-label fw-bold mb-0">Documentos adjuntados:</label>

                                    <button type="button"
                                            id="btnAgregarDocumento"
                                            class="btn btn-link text-decoration-none p-0"
                                            title="Agregar documento">
                                        <i class="bi bi-file-earmark-plus-fill text-primary" style="font-size:28px;"></i>
                                    </button>
                                </div>

                                <div class="border rounded-3 p-3 bg-light">
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered table-hover mb-0 align-middle">
                                            <thead class="table-secondary">
                                                <tr>
                                                    <th>Tipo Documento</th>
                                                    <th class="text-center" style="width:120px;">Link</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (Model.DocumentosAdjuntos != null && Model.DocumentosAdjuntos.Any())
                                                {
                                                    @foreach (var doc in Model.DocumentosAdjuntos)
                                                    {
                                                        <tr>
                                                            <td>@doc.TipoDocumentoDesc</td>
                                                            <td class="text-center">
                                                                <a href="@doc.DocumentoAlfresco" target="_blank" title="Ver documento">
                                                                    <img src="/Images/Icons/file-earmark-text.svg"
                                                                         alt="Documento"
                                                                         style="width:20px; height:20px;" />
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td colspan="2" class="text-center text-muted">
                                                            No hay documentos adjuntos.
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- DILIGENCIAS -->
                        <div class="mb-5">
                            <div class="text-center mb-4">
                                <h4 class="fw-bold">DILIGENCIAS</h4>
                                <hr class="mt-2" />
                            </div>

                            <div class="table-responsive mt-2">
                                <table class="table table-bordered table-striped table-hover align-middle">
                                    <thead class="thead-tua">
                                        <tr>
                                            <th>Diligencia</th>
                                            <th>Destinatario</th>
                                            <th>Fecha Diligencia</th>
                                            <th>Estatus</th>
                                            <th class="text-center">Ver</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (diligenciasPaginadas.Any())
                                        {
                                            foreach (var d in diligenciasPaginadas)
                                            {
                                                <tr>
                                                    <td>@d.TipoDiligenciaDesc</td>
                                                    <td>@d.Destinatario</td>
                                                    <td>@(d.FechaDiligencia.HasValue? d.FechaDiligencia.Value.ToString("dd/MM/yyyy") : "")</td>
                                                    <td>@d.EstatusDiligencia</td>
                                                    <td class="text-center">
                                                        <a asp-controller="Diligencias"
                                                               asp-action="SeguimientoDiligencia"
                                                               asp-route-diligenciaId="@d.DiligenciaId"
                                                               asp-route-exhortoId="@d.ExhortoId"
                                                               title="Ver seguimiento">
                                                            <img src="@Url.Content("~/images/Icons/pencil.svg")"
                                                                 alt="Editar"
                                                                 style="width:20px; height:20px; cursor:pointer;" />
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center text-muted">
                                                    No hay diligencias registradas.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        @{
                            var exhorto = Model?.Exhorto;
                        }

                        @if (exhorto != null)
                        {
                            <!-- SEGUIMIENTO -->
                            <div class="mb-4">
                                <div class="text-center mb-4">
                                    <h4 class="fw-bold">SEGUIMIENTO</h4>
                                    <hr class="mt-2" />
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-md-6 col-lg-3">
                                        <label class="form-label fw-bold">No. Exhorto Recibido:</label>
                                        <div class="form-control bg-light">
                                            @exhorto.NoExhortoRecibido
                                        </div>
                                    </div>

                                    <div class="col-md-6 col-lg-3">
                                        <label class="form-label fw-bold">TUA Exhortado:</label>
                                        <div class="form-control bg-light">
                                            @exhorto.TuaDestino
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(exhorto.FechaNuevoAcuerdo))
                                    {
                                        <div class="col-md-6 col-lg-3">
                                            <label class="form-label fw-bold">Fecha Nuevo Acuerdo:</label>
                                            <div class="form-control bg-light">
                                                @(DateTime.TryParse(exhorto.FechaNuevoAcuerdo, out var fechaNuevoAcuerdo)
                                                    ? fechaNuevoAcuerdo.ToString("dd/MM/yyyy")
                                                    : exhorto.FechaNuevoAcuerdo)
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(exhorto.FechaNuevaAudiencia))
                                    {
                                        <div class="col-md-6 col-lg-3">
                                            <label class="form-label fw-bold">Fecha Nueva Audiencia:</label>
                                            <div class="form-control bg-light">
                                                @(DateTime.TryParse(exhorto.FechaNuevaAudiencia, out var fechaNuevaAudiencia)
                                                    ? fechaNuevaAudiencia.ToString("dd/MM/yyyy")
                                                    : exhorto.FechaNuevaAudiencia)
                                            </div>
                                        </div>
                                    }
                                </div>

                                <form asp-action="GuardarSeguimiento"
                                      asp-controller="SeguimientoExhortos"
                                      method="post">

                                    <input type="hidden" asp-for="Seguimiento.ExhortoId" />
                                    <input type="hidden" asp-for="Seguimiento.FechaAudiencia" />

                                    <div asp-validation-summary="ModelOnly" class="alert alert-warning"></div>

                                    <div class="row g-3 mb-3">
                                        <div class="col-md-6 col-lg-4">
                                            <label class="form-label fw-bold">* Fecha de Recepción:</label>
                                            <div class="input-group">
                                                <span class="input-group-text" id="iconoFechaRecepcion" style="cursor:pointer;">
                                                    <i class="bi bi-calendar-date"></i>
                                                </span>
                                                <input asp-for="Seguimiento.FechaRecepcion"
                                                       type="date"
                                                       class="form-control sin-icono" />
                                            </div>
                                            <span asp-validation-for="Seguimiento.FechaRecepcion" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-6 col-lg-4">
                                            <label class="form-label fw-bold">* No. Folio:</label>
                                            <input asp-for="Seguimiento.NoFolio"
                                                   class="form-control text-uppercase" />
                                            <span asp-validation-for="Seguimiento.NoFolio" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-12 col-lg-4">
                                            <label class="form-label fw-bold">* Estatus del Exhorto:</label>
                                            <select asp-for="Seguimiento.Estatus" class="form-control">
                                                <option value="">Seleccione</option>
                                                <option value="TRAMITE">TRAMITE</option>
                                                <option value="ATENDIDO">ATENDIDO</option>
                                                <option value="NO DILIGENCIADO">NO DILIGENCIADO</option>
                                                <option value="PARCIALMENTE ATENDIDO">PARCIALMENTE ATENDIDO</option>
                                            </select>
                                            <span asp-validation-for="Seguimiento.Estatus" class="text-danger"></span>
                                        </div>
                                    </div>

                                    <div class="row g-3 mb-3">
                                        <div class="col-md-6 col-lg-3">
                                            <label class="form-label fw-bold">* Fecha Acuerdo TUA Exhortado:</label>
                                            <div class="input-group">
                                                <span class="input-group-text" id="iconoFechaAcuerdoTuaExhortado" style="cursor:pointer;">
                                                    <i class="bi bi-calendar-date"></i>
                                                </span>
                                                <input asp-for="Seguimiento.FechaAcuerdoTuaExhortado"
                                                       type="date"
                                                       class="form-control sin-icono" />
                                            </div>
                                            <span asp-validation-for="Seguimiento.FechaAcuerdoTuaExhortado" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-6 col-lg-3">
                                            <label class="form-label fw-bold">* Fecha Turno Actuaría:</label>
                                            <div class="input-group">
                                                <span class="input-group-text" id="iconoFechaTurnoActuaria" style="cursor:pointer;">
                                                    <i class="bi bi-calendar-date"></i>
                                                </span>
                                                <input asp-for="Seguimiento.FechaTurnoActuaria"
                                                       type="date"
                                                       class="form-control sin-icono" />
                                            </div>
                                            <span asp-validation-for="Seguimiento.FechaTurnoActuaria" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-6 col-lg-3">
                                            <label class="form-label fw-bold">Fecha de Vencimiento:</label>
                                            <div class="input-group">
                                                <span class="input-group-text" id="iconoFechaVencimiento" style="cursor:pointer;">
                                                    <i class="bi bi-calendar-date"></i>
                                                </span>
                                                <input asp-for="Seguimiento.FechaVencimiento"
                                                       type="date"
                                                       class="form-control sin-icono" />
                                            </div>
                                            <span asp-validation-for="Seguimiento.FechaVencimiento" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-6 col-lg-3">
                                            <label class="form-label fw-bold">* Fecha Devolución:</label>
                                            <div class="input-group">
                                                <span class="input-group-text" id="iconoFechaDevolucion" style="cursor:pointer;">
                                                    <i class="bi bi-calendar-date"></i>
                                                </span>
                                                <input asp-for="Seguimiento.FechaDevolucion"
                                                       type="date"
                                                       class="form-control sin-icono" />
                                            </div>
                                            <span asp-validation-for="Seguimiento.FechaDevolucion" class="text-danger"></span>
                                        </div>
                                    </div>

                                    <div class="row g-3 mb-3">
                                        <div class="col-12">
                                            <label class="form-label fw-bold">Observaciones:</label>
                                            <textarea asp-for="Seguimiento.Observaciones"
                                                      class="form-control text-uppercase"
                                                      rows="4"
                                                      oninput="this.value = this.value.toUpperCase()"></textarea>
                                            <span asp-validation-for="Seguimiento.Observaciones" class="text-danger"></span>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-end gap-2 flex-wrap">
                                        <a asp-controller="SeguimientoExhortos"
                                               asp-action="SeguimientoExhortos"
                                               class="btn btn-secondary">
                                            Regresar
                                        </a>

                                        <button type="submit" class="btn btn-tua">
                                            Guardar
                                        </button>
                                    </div>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center">
                                No se encontró información del seguimiento del exhorto.
                            </div>
                        }

                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade"
     id="modalDocumentos"
     tabindex="-1"
     aria-labelledby="modalDocumentosLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDocumentosLabel">
                    Adjuntar documentos
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>
            </div>
            <div class="modal-body" id="contenedorModalDocumentos">
                <div class="text-center py-4">
                    Cargando...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function activarCalendario(iconoId, inputId) {
            const icono = document.getElementById(iconoId);
            const input = document.getElementById(inputId);

            if (icono && input) {
                icono.addEventListener("click", function () {
                    if (input.showPicker) {
                        input.showPicker();
                    } else {
                        input.focus();
                        input.click();
                    }
                });
            }
        }

        function inicializarModalDocumentos() {
            const tipoDocumento = document.getElementById("tipoDocumentoModal");
            const documentoAlfresco = document.getElementById("documentoAlfrescoModal");
            const btnAgregar = document.getElementById("btnAgregarDocumentoModal");
            const btnGuardar = document.getElementById("btnGuardarDocumentosModal");
            const tabla = document.querySelector("#tablaDocumentosModal tbody");
            const contenedor = document.getElementById("contenedorHiddenDocumentosModal");
            const form = document.getElementById("formAltaDocumentosModal");
            const noExhorto = document.getElementById("NoExhortoHiddenModal").value;
            const mensajeDocumentos = document.getElementById("mensajeDocumentosModal");
            const errorTipoDocumento = document.getElementById("errorTipoDocumentoModal");
            const errorDocumentoAlfresco = document.getElementById("errorDocumentoAlfrescoModal");

            if (!tipoDocumento || !documentoAlfresco || !btnAgregar || !btnGuardar || !tabla || !contenedor || !form) {
                return;
            }

            let documentos = [];

            const escapeHtml = (texto) =>
                (texto || "")
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll('"', "&quot;")
                    .replaceAll("'", "&#39;");

            const limpiarErrores = () => {
                errorTipoDocumento.classList.add("d-none");
                errorDocumentoAlfresco.classList.add("d-none");
                tipoDocumento.classList.remove("is-invalid");
                documentoAlfresco.classList.remove("is-invalid");
            };

            const validarCaptura = () => {
                limpiarErrores();

                let esValido = true;

                if (!tipoDocumento.value) {
                    tipoDocumento.classList.add("is-invalid");
                    errorTipoDocumento.classList.remove("d-none");
                    esValido = false;
                }

                if (!documentoAlfresco.value.trim()) {
                    documentoAlfresco.classList.add("is-invalid");
                    errorDocumentoAlfresco.classList.remove("d-none");
                    esValido = false;
                }

                return esValido;
            };

            const render = () => {
                tabla.innerHTML = "";
                contenedor.innerHTML = "";

                if (documentos.length === 0) {
                    tabla.innerHTML = `
                        <tr id="filaSinDocumentosModal">
                            <td colspan="3" class="text-center text-muted">
                                No hay documentos agregados.
                            </td>
                        </tr>
                    `;
                    mensajeDocumentos.classList.add("d-none");
                    return;
                }

                documentos.forEach((d, i) => {
                    tabla.innerHTML += `
                        <tr>
                            <td>${escapeHtml(d.desc)}</td>
                            <td class="text-center">
                                <a href="${escapeHtml(d.url)}" target="_blank" title="Ver documento">
                                    <i class="bi bi-file-earmark-text text-primary fs-5"></i>
                                </a>
                            </td>
                            <td class="text-center">
                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        data-index="${i}">
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    `;

                    contenedor.innerHTML += `
                        <input type="hidden" name="Documentos.Index" value="${i}" />
                        <input type="hidden" name="Documentos[${i}].NoExhorto" value="${escapeHtml(noExhorto)}" />
                        <input type="hidden" name="Documentos[${i}].TipoDocumentoId" value="${escapeHtml(d.id)}" />
                        <input type="hidden" name="Documentos[${i}].Documento" value="${escapeHtml(d.url)}" />
                    `;
                });

                tabla.querySelectorAll(".btn-danger").forEach(btn => {
                    btn.addEventListener("click", function () {
                        const index = parseInt(this.getAttribute("data-index"));
                        documentos.splice(index, 1);
                        render();
                    });
                });

                mensajeDocumentos.classList.add("d-none");
            };

            btnAgregar.addEventListener("click", function () {
                if (!validarCaptura()) {
                    return;
                }

                documentos.push({
                    id: tipoDocumento.value,
                    desc: tipoDocumento.options[tipoDocumento.selectedIndex].text.trim(),
                    url: documentoAlfresco.value.trim()
                });

                render();

                tipoDocumento.value = "";
                documentoAlfresco.value = "";
                limpiarErrores();
            });

            btnGuardar.addEventListener("click", async function () {
                if (documentos.length === 0) {
                    mensajeDocumentos.classList.remove("d-none");
                    return;
                }

                render();

                const formData = new FormData(form);

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: formData
                    });

                    const resultado = await response.json();

                    if (!resultado.ok) {
                        alert(resultado.mensaje);
                        return;
                    }

                    alert(resultado.mensaje);

                    const modalElement = document.getElementById("modalDocumentos");
                    const modalInstance = bootstrap.Modal.getInstance(modalElement);

                    if (modalInstance) {
                        modalInstance.hide();
                    }
                }
                catch (error) {
                    alert("Ocurrió un error al guardar los documentos.");
                }
            });

            render();
        }

        activarCalendario("iconoFechaRecepcion", "Seguimiento_FechaRecepcion");
        activarCalendario("iconoFechaAcuerdoTuaExhortado", "Seguimiento_FechaAcuerdoTuaExhortado");
        activarCalendario("iconoFechaTurnoActuaria", "Seguimiento_FechaTurnoActuaria");
        activarCalendario("iconoFechaVencimiento", "Seguimiento_FechaVencimiento");
        activarCalendario("iconoFechaDevolucion", "Seguimiento_FechaDevolucion");

        document.getElementById("btnAgregarDocumento").addEventListener("click", function () {
            const noExhorto = document.getElementById("noExhortoModal").value;
            const url = '/Exhortos/CargarModalDocumentos?noExhorto=' + encodeURIComponent(noExhorto);

            fetch(url)
                .then(response => {
                    if (!response.ok) {
                        throw new Error("No fue posible cargar el formulario de documentos.");
                    }

                    return response.text();
                })
                .then(html => {
                    document.getElementById("contenedorModalDocumentos").innerHTML = html;
                    inicializarModalDocumentos();

                    const modal = new bootstrap.Modal(document.getElementById("modalDocumentos"));
                    modal.show();
                })
                .catch(error => {
                    document.getElementById("contenedorModalDocumentos").innerHTML =
                        '<div class="alert alert-danger text-center">' + error.message + '</div>';

                    const modal = new bootstrap.Modal(document.getElementById("modalDocumentos"));
                    modal.show();
                });
        });
    </script>
}