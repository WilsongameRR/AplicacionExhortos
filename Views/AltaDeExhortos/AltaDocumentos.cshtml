@model AplicacionExhortos.Models.Exhortos.AltaDocumentosViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Alta de Documentos";

    string noExhorto = Model?.NoExhorto ?? string.Empty;
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:80px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-8">

            <div class="text-center mt-4 mb-4">
                <h2>ALTA DE DOCUMENTOS</h2>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show text-center mt-3" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert">
                    @TempData["Exito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="col-12 text-start mt-2">
                <small class="text-muted">
                    Los campos marcados con <span class="text-danger">*</span> son obligatorios.
                </small>
            </div>

            <div class="card shadow-sm border-0" style="background-color: rgba(255,255,255,0.96);">
                <div class="card-body px-4 py-4">

                    <div class="text-center mb-4">
                        <h4 class="fw-bold">Adjuntar documentos</h4>
                    </div>

                    <form id="formAltaDocumentos"
                          asp-action="GuardarDocumentos"
                          asp-controller="Exhortos"
                          method="post"
                          novalidate>
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="NoExhorto" id="NoExhortoHidden" />

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">No. Exhorto:</label>
                                <div class="form-control bg-light">@noExhorto</div>
                            </div>
                        </div>

                        <div class="row align-items-end mb-4">
                            <div class="col-md-4">
                                <label for="tipoDocumento" class="form-label fw-bold">
                                    <span class="text-danger">*</span> Tipo de documento:
                                </label>
                                <select id="tipoDocumento" class="form-select">
                                    <option value="">Seleccione</option>
                                    @if (ViewBag.TiposDocumento != null)
                                    {
                                        foreach (var item in ViewBag.TiposDocumento)
                                        {
                                            <option value="@item.TipoDoctoId">@item.TipoDoctoDesc</option>
                                        }
                                    }
                                </select>
                                <div id="errorTipoDocumento" class="text-danger small d-none">
                                    Debe seleccionar el tipo de documento.
                                </div>
                            </div>

                            <div class="col-md-7">
                                <label for="documentoAlfresco" class="form-label fw-bold">
                                    <span class="text-danger">*</span> Documento Alfresco:
                                </label>
                                <input type="text"
                                       id="documentoAlfresco"
                                       class="form-control"
                                       maxlength="300"
                                       placeholder="Ingrese la ruta o referencia del documento" />
                                <div id="errorDocumentoAlfresco" class="text-danger small d-none">
                                    Debe capturar el documento Alfresco.
                                </div>
                            </div>

                            <div class="col-md-1 text-center">
                                <button type="button"
                                        id="btnAgregarDocumento"
                                        class="btn btn-link text-decoration-none p-0"
                                        title="Agregar documento">
                                    <i class="bi bi-file-earmark-arrow-up-fill text-primary" style="font-size:32px;"></i>
                                </button>
                            </div>
                        </div>

                        <div class="table-responsive mb-2">
                            <table class="table table-bordered table-striped align-middle" id="tablaDocumentos">
                                <thead class="thead-tua">
                                    <tr>
                                        <th style="width:55%;">Tipo de documento</th>
                                        <th class="text-center" style="width:25%;">Link</th>
                                        <th class="text-center" style="width:20%;">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr id="filaSinDocumentos">
                                        <td colspan="3" class="text-center text-muted">
                                            No hay documentos agregados.
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div id="contenedorHiddenDocumentos"></div>

                        <div id="mensajeDocumentos" class="text-danger text-center mt-2 d-none">
                            Debe agregar al menos un documento antes de guardar.
                        </div>

                        <div class="text-center mt-4">
                            <button type="button" id="btnGuardarDocumentos" class="btn btn-tua px-4">
                                Guardar
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const tipoDocumento = document.getElementById("tipoDocumento");
            const documentoAlfresco = document.getElementById("documentoAlfresco");
            const btnAgregar = document.getElementById("btnAgregarDocumento");
            const btnGuardar = document.getElementById("btnGuardarDocumentos");
            const tabla = document.querySelector("#tablaDocumentos tbody");
            const contenedor = document.getElementById("contenedorHiddenDocumentos");
            const form = document.getElementById("formAltaDocumentos");
            const noExhorto = document.getElementById("NoExhortoHidden").value;
            const mensajeDocumentos = document.getElementById("mensajeDocumentos");
            const errorTipoDocumento = document.getElementById("errorTipoDocumento");
            const errorDocumentoAlfresco = document.getElementById("errorDocumentoAlfresco");

            let documentos = [];

            const escapeHtml = (texto) =>
                (texto || "")
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll('"', "&quot;")
                    .replaceAll("'", "&#39;");

            const limpiarErrores = () => {
                errorTipoDocumento.classList.add("d-none");
                errorDocumentoAlfresco.classList.add("d-none");
                tipoDocumento.classList.remove("is-invalid");
                documentoAlfresco.classList.remove("is-invalid");
            };

            const validarCaptura = () => {
                limpiarErrores();

                let esValido = true;

                if (!tipoDocumento.value) {
                    tipoDocumento.classList.add("is-invalid");
                    errorTipoDocumento.classList.remove("d-none");
                    esValido = false;
                }

                if (!documentoAlfresco.value.trim()) {
                    documentoAlfresco.classList.add("is-invalid");
                    errorDocumentoAlfresco.classList.remove("d-none");
                    esValido = false;
                }

                return esValido;
            };

            const render = () => {
                tabla.innerHTML = "";
                contenedor.innerHTML = "";

                if (documentos.length === 0) {
                    tabla.innerHTML = `
                        <tr id="filaSinDocumentos">
                            <td colspan="3" class="text-center text-muted">
                                No hay documentos agregados.
                            </td>
                        </tr>
                    `;
                    mensajeDocumentos.classList.add("d-none");
                    return;
                }

                documentos.forEach((d, i) => {
                    tabla.innerHTML += `
                        <tr>
                            <td>${escapeHtml(d.desc)}</td>
                            <td class="text-center">
                                <a href="${escapeHtml(d.url)}" target="_blank" title="Ver documento">
                                    <img src="/Images/Icons/file-earmark-text.svg"
                                         alt="Documento"
                                         style="width:18px; height:18px;" />
                                </a>
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-danger btn-sm" onclick="eliminar(${i})">
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    `;

                    contenedor.innerHTML += `
                        <input type="hidden" name="Documentos.Index" value="${i}" />
                        <input type="hidden" name="Documentos[${i}].NoExhorto" value="${escapeHtml(noExhorto)}" />
                        <input type="hidden" name="Documentos[${i}].TipoDocumentoId" value="${escapeHtml(d.id)}" />
                        <input type="hidden" name="Documentos[${i}].Documento" value="${escapeHtml(d.url)}" />
                    `;
                });

                mensajeDocumentos.classList.add("d-none");
            };

            btnAgregar.onclick = () => {
                if (!validarCaptura()) {
                    return;
                }

                documentos.push({
                    id: tipoDocumento.value,
                    desc: tipoDocumento.options[tipoDocumento.selectedIndex].text.trim(),
                    url: documentoAlfresco.value.trim()
                });

                render();

                tipoDocumento.value = "";
                documentoAlfresco.value = "";
                limpiarErrores();
            };

            btnGuardar.onclick = () => {
                if (documentos.length === 0) {
                    mensajeDocumentos.classList.remove("d-none");
                    return;
                }

                render();
                form.submit();
            };

            window.eliminar = (i) => {
                documentos.splice(i, 1);
                render();
            };

            setTimeout(() => {
                const alerts = document.querySelectorAll(".alert");
                alerts.forEach((alert) => {
                    alert.style.transition = "opacity 0.5s ease, transform 0.5s ease";
                    alert.style.opacity = "0";
                    alert.style.transform = "translateY(-10px)";
                    setTimeout(() => alert.remove(), 500);
                });
            }, 3000);

            render();
        })();
    </script>
}