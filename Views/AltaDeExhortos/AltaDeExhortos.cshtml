@model AplicacionExhortos.Models.Exhortos.AltaExhortoModel

@{
    ViewData["Title"] = "Alta de Exhortos";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:40px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>ALTA DE EXHORTOS</h2>
            </div>

            <div class="col-12 text-start mt-2">
                <small class="text-muted">
                    Los campos marcados con <span class="text-danger">*</span> son obligatorios.
                </small>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger text-center">
                    @TempData["Error"]
                </div>
            }

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success text-center">
                    <strong>@TempData["MensajeExito"]</strong><br />
                    Número de exhorto generado:
                    <strong>@TempData["NumeroExhorto"]</strong>
                </div>
            }

            <form id="formAltaExhortos"
                  asp-controller="Exhortos"
                  asp-action="Guardar"
                  method="post"
                  class="row g-3 needs-validation"
                  novalidate>

                @Html.AntiForgeryToken()

                <div class="col-md-4">
                    <label class="form-label">* Expediente</label>
                    <input asp-for="Expediente"
                           class="form-control text-uppercase"
                           required
                           title="Ingrese Numero de Expediente" />
                    <div class="invalid-feedback"></div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">* No. Oficio</label>
                    <input asp-for="NoOficio" class="form-control text-uppercase" required />
                    <div class="invalid-feedback">Ingrese el número de oficio.</div>
                </div>

                <div class="col-md-4"></div>

                <div class="col-md-4">
                    <label class="form-label">* Estado del Expediente</label>
                    <input asp-for="Estado"
                           class="form-control text-uppercase"
                           required
                           pattern="^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9\s.,/-]+$"
                           title="Se permiten letras, números, espacios, puntos, diagonales, comas y guion medio" />
                    <div class="invalid-feedback">
                        Ingrese un valor válido.
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">* Municipio del Expediente</label>
                    <input asp-for="Municipio"
                           class="form-control text-uppercase"
                           required
                           pattern="^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9\s.,/-]+$"
                           title="Se permiten letras, números, espacios, puntos, diagonales, comas y guion medio" />
                    <div class="invalid-feedback">
                        Ingrese un valor válido.
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">* Poblado del Expediente</label>
                    <input asp-for="Poblado"
                           class="form-control text-uppercase"
                           required
                           pattern="^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9\s.,/-]+$"
                           title="Se permiten letras, números, espacios, puntos, diagonales, comas y guion medio" />
                    <div class="invalid-feedback">
                        Ingrese un valor válido.
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">* TUA Exhortado</label>
                    <select asp-for="TuaExhortado" class="form-select" required>
                        <option value="">Seleccione...</option>

                        @if (ViewBag.TUAs != null)
                        {
                            foreach (var tua in ViewBag.TUAs)
                            {
                                <option value="@tua.TUAId">@tua.NumTUA</option>
                            }
                        }
                    </select>
                    <div class="invalid-feedback">Seleccione un TUA Exhortado.</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">* Fecha de Acuerdo</label>
                    <div class="input-group has-validation">
                        <span class="input-group-text" id="iconoCalendarioAcuerdo" style="cursor:pointer;">
                            <i class="bi bi-calendar-event"></i>
                        </span>

                        <input asp-for="FechaGeneral"
                               type="date"
                               class="form-control sin-icono"
                               min="@DateTime.Today.AddYears(-1).ToString("yyyy-MM-dd")"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")"
                               required />

                        <div class="invalid-feedback">
                            Ingrese una fecha de acuerdo.
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">* Fecha de Audiencia</label>
                    <div class="input-group has-validation">
                        <span class="input-group-text" id="iconoCalendarioAudiencia" style="cursor:pointer;">
                            <i class="bi bi-calendar-event"></i>
                        </span>
                        <input asp-for="FechaAudiencia"
                               type="date"
                               class="form-control sin-icono"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               max="@DateTime.Today.AddYears(1).ToString("yyyy-MM-dd")"
                               required />

                        <div class="invalid-feedback">
                            Ingrese una Fecha de Audiencia 
                        </div>
                    </div>
                </div>

                <div class="col-12 text-center mt-4">
                    <button type="submit" class="btn btn-tua me-2">
                        Guardar
                    </button>

                    <button type="reset" class="btn btn-secondary">
                        Cancelar
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        (() => {
            'use strict';

            const forms = document.querySelectorAll('.needs-validation');

            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {

                    const inputs = form.querySelectorAll("input[type='text']");
                    inputs.forEach(input => {
                        input.value = input.value.toUpperCase();
                    });

                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }

                    form.classList.add('was-validated');

                }, false);
            });
        })();
    </script>

    <script>
        const iconoCalendarioAcuerdo = document.getElementById("iconoCalendarioAcuerdo");
        const fechaGeneral = document.getElementById("FechaGeneral");

        if (iconoCalendarioAcuerdo && fechaGeneral) {
            iconoCalendarioAcuerdo.addEventListener("click", function () {
                if (fechaGeneral.showPicker) {
                    fechaGeneral.showPicker();
                } else {
                    fechaGeneral.focus();
                    fechaGeneral.click();
                }
            });
        }

        const iconoCalendarioAudiencia = document.getElementById("iconoCalendarioAudiencia");
        const fechaAudiencia = document.getElementById("FechaAudiencia");

        if (iconoCalendarioAudiencia && fechaAudiencia) {
            iconoCalendarioAudiencia.addEventListener("click", function () {
                if (fechaAudiencia.showPicker) {
                    fechaAudiencia.showPicker();
                } else {
                    fechaAudiencia.focus();
                    fechaAudiencia.click();
                }
            });
        }
    </script>

    <script>
        const formAltaExhortos = document.getElementById("formAltaExhortos");

        if (formAltaExhortos) {
            formAltaExhortos.addEventListener("reset", function () {

                setTimeout(() => {

                    formAltaExhortos.classList.remove("was-validated");

                    const camposInvalidos = formAltaExhortos.querySelectorAll(".is-invalid");

                    camposInvalidos.forEach(campo => {
                        campo.classList.remove("is-invalid");
                    });

                }, 0);

            });
        }
    </script>
}