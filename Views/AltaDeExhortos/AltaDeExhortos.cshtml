@model AplicacionExhortos.Models.Exhortos.AltaExhortoModel

@{
    ViewData["Title"] = "Alta de Exhortos";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:40px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>ALTA DE EXHORTOS</h2>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger text-center">
                    @TempData["Error"]
                </div>
            }

            @if (TempData["NumeroExhorto"] != null)
            {
                <div class="alert alert-success text-center">
                    Exhorto guardado correctamente. Número de exhorto:
                    <strong>@TempData["NumeroExhorto"]</strong>
                </div>

                <div class="text-center mt-3 mb-4">
                    <h5>DILIGENCIAS</h5>
                    <p>Después de guardar el exhorto puede agregar una o más diligencias.</p>

                    <a asp-controller="Diligencias"
                       asp-action="AltaDiligencia"
                       asp-route-idExhorto="@TempData["IdExhorto"]"
                       class="btn btn-tua me-2">
                        Agregar diligencia
                    </a>

                    <a asp-controller="ExhortosConsulta"
                       asp-action="ExhortosConsulta"
                       class="btn btn-secondary">
                        Finalizar
                    </a>
                </div>
            }
            else
            {
                <form id="formAltaExhortos"
                      asp-controller="Exhortos"
                      asp-action="Guardar"
                      method="post"
                      class="row g-3 needs-validation"
                      novalidate>

                    @Html.AntiForgeryToken()

                    <div class="col-md-4">
                        <label asp-for="Expediente" class="form-label"></label>
                        <input asp-for="Expediente" class="form-control" required />
                        <div class="invalid-feedback">Ingrese el expediente.</div>
                        <span asp-validation-for="Expediente" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="NoOficio" class="form-label"></label>
                        <input asp-for="NoOficio" class="form-control" required />
                        <div class="invalid-feedback">Ingrese el número de oficio.</div>
                        <span asp-validation-for="NoOficio" class="text-danger"></span>
                    </div>

                    <div class="col-md-4"></div>

                    <div class="col-md-4">
                        <label asp-for="Estado" class="form-label"></label>
                        <input asp-for="Estado" class="form-control" required />
                        <div class="invalid-feedback">Ingrese el estado.</div>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Municipio" class="form-label"></label>
                        <input asp-for="Municipio" class="form-control" required />
                        <div class="invalid-feedback">Ingrese el municipio.</div>
                        <span asp-validation-for="Municipio" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Poblado" class="form-label"></label>
                        <input asp-for="Poblado" class="form-control" required />
                        <div class="invalid-feedback">Ingrese el poblado.</div>
                        <span asp-validation-for="Poblado" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TuaExhortado" class="form-label"></label>
                        <select asp-for="TuaExhortado" class="form-select" required>
                            <option value="">Seleccione...</option>

                            @if (ViewBag.TUAs != null)
                            {
                                @foreach (var tua in ViewBag.TUAs)
                                {
                                    <option value="@tua.TUAId">@tua.NumTUA</option>
                                }
                            }
                        </select>
                        <div class="invalid-feedback">Seleccione un TUA Exhortado.</div>
                        <span asp-validation-for="TuaExhortado" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="FechaGeneral" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text" id="iconoCalendario" style="cursor:pointer;">
                                <i class="bi bi-calendar-event"></i>
                            </span>

                            <input asp-for="FechaGeneral"
                                   type="date"
                                   class="form-control sin-icono" />
                        </div>
                        <span asp-validation-for="FechaGeneral" class="text-danger"></span>
                    </div>

                    <div class="col-md-4"></div>

                    <div class="col-12 text-center mt-4">
                        <button type="submit" class="btn btn-tua me-2">
                            Guardar
                        </button>

                        <a asp-controller="ExhortosEnviados"
                           asp-action="ExhortosEnviados"
                           class="btn btn-secondary">
                            Cancelar
                        </a>
                    </div>

                </form>
            }

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (() => {
            'use strict';

            const form = document.getElementById('formAltaExhortos');

            if (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }

                    form.classList.add('was-validated');
                });
            }
        })();
    </script>

    <script>
        const iconoCalendario = document.getElementById("iconoCalendario");
        const fechaGeneral = document.getElementById("FechaGeneral");

        if (iconoCalendario && fechaGeneral) {
            iconoCalendario.addEventListener("click", function () {
                if (fechaGeneral.showPicker) {
                    fechaGeneral.showPicker();
                } else {
                    fechaGeneral.focus();
                    fechaGeneral.click();
                }
            });
        }
    </script>
}