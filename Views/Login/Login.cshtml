@model AplicacionExhortos.Models.Login.LoginModel

@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    ViewData["Title"] = "Acceso";
}

<div class="container-fluid">
    <div class="row min-vh-100">

        <div class="col-12 col-lg-6 p-0"
             style="background: url('/Images/ImagenTSA.jpg') center center / cover no-repeat;
                    min-height: 280px;">
        </div>

        <div class="col-12 col-lg-6 d-flex flex-column p-4">

            <div class="text-center pt-3">
                <h4 class="fw-bold">
                    TRIBUNAL SUPERIOR AGRARIO <br />
                    UNIDAD GENERAL ADMINISTRATIVA <br />
                    UNIDAD DE TECNOLOGÍAS <br />
                    DE LA INFORMACIÓN Y COMUNICACIONES
                </h4>
            </div>

            <div class="d-flex justify-content-center align-items-center flex-grow-1">
                <div class="w-100" style="max-width:420px;">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <form id="formLogin"
                          class="needs-validation"
                          novalidate
                          asp-controller="Login"
                          asp-action="Login"
                          method="post">

                        @Html.AntiForgeryToken()

                        <h5 class="mb-4 text-center">
                            SISTEMA DE CAPTURA DE EXHORTOS <br />
                            TRIBUNALES UNITARIOS AGRARIOS
                        </h5>

                        <div class="mb-3">
                            <label asp-for="Usuario" class="form-label"></label>
                            <input asp-for="Usuario"
                                   type="email"
                                   class="form-control"
                                   required
                                   pattern="^[a-zA-Z0-9._%+-]+@@tribunalesagrarios\.gob\.mx$"
                                   title="Debe ingresar su correo"
                                   placeholder="" />
                            <div class="invalid-feedback">
                            </div>
                            <span asp-validation-for="Usuario" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control"
                                   required
                                   title="La contraseña es obligatoria" />
                            <div class="invalid-feedback">
                                Ingrese contraseña.
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-tua w-50">
                                Aceptar
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (() => {
            'use strict';

            const form = document.getElementById('formLogin');

            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }

                form.classList.add('was-validated');
            }, false);
        })();
    </script>
}