@model AplicacionExhortos.Models.AltaDiligenciasModel
@using AplicacionExhortos.Models
@{
    ViewData["Title"] = "Alta de Diligencia";
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:40px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>ALTA DE DILIGENCIAS</h2>
            </div>

            <div class="col-12 text-start mt-2">
                <small class="text-muted">
                    Los campos marcados con <span class="text-danger">*</span> son obligatorios.
                </small>
            </div>

            <form id="formDiligencias"
                  method="post"
                  asp-controller="Diligencias"
                  asp-action="GuardarDiligencias"
                  novalidate>

                <input type="hidden" asp-for="NoExhorto" id="NoExhortoHidden" />

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">
                            <span class="required">*</span> No. de Exhorto
                        </label>
                        <input type="text"
                               asp-for="NoExhorto"
                               class="form-control text-uppercase"
                               id="NoExhorto"
                               maxlength="200" />
                        <div class="invalid-feedback">
                            Capture el número de exhorto.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">
                            <span class="required">*</span> Tipo diligencia
                        </label>
                        <select class="form-select" id="TipoDiligenciaId">
                            <option value="">Seleccione...</option>
                            <option value="1">CITAR</option>
                            <option value="2">EMPLAZAR</option>
                            <option value="3">NOTIFICAR</option>
                            <option value="4">OTRA</option>
                        </select>
                        <div class="invalid-feedback">
                            Seleccione un tipo de diligencia.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">
                            <span class="required">*</span> Destinatario
                        </label>
                        <input type="text"
                               name="Destinatario"
                               class="form-control text-uppercase"
                               id="Destinatario"
                               maxlength="200" />
                        <div class="invalid-feedback">
                            Capture el destinatario.
                        </div>
                    </div>

                    <div class="col-md-4 d-none" id="bloqueOtro">
                        <label class="form-label">
                            <span class="required">*</span> Especifique diligencia
                        </label>
                        <input type="text"
                               class="form-control text-uppercase"
                               id="Otro"
                               maxlength="80" />
                        <div class="invalid-feedback">
                            Especifique la diligencia.
                        </div>
                    </div>

                    <div class="col-12 text-center mt-3">
                        <button type="button"
                                id="btnAgregarDiligencia"
                                class="btn btn-tua">
                            Agregar
                        </button>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="mt-3">
                    <h4 class="text-center mb-3">DILIGENCIAS AGREGADAS</h4>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="tablaDiligencias">
                            <thead>
                                <tr>
                                    <th>No. Exhorto</th>
                                    <th>Tipo diligencia</th>
                                    <th>Destinatario</th>
                                    <th>Otro</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div id="contenedorHiddenDiligencias"></div>

                <div id="mensajeDiligencias" class="text-danger text-center mt-2 d-none">
                    Debe agregar al menos una diligencia antes de guardar.
                </div>

                <div class="col-12 text-center mt-4">
                    <button type="submit" id="btnGuardarDili" class="btn btn-success me-2">
                        Guardar diligencias
                    </button>

                    <button type="reset" class="btn btn-secondary">
                        Cancelar
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
    <div id="toastDiligenciaGuardada"
         class="toast align-items-center text-bg-success border-0"
         role="alert"
         aria-live="assertive"
         aria-atomic="true"
         data-bs-delay="1200">
        <div class="d-flex">
            <div class="toast-body">
                Diligencias guardadas correctamente.
            </div>
            <button type="button"
                    class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast"
                    aria-label="Cerrar"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const formDiligencias = document.getElementById("formDiligencias");
        const tipoDiligencia = document.getElementById("TipoDiligenciaId");
        const noExhorto = document.getElementById("NoExhorto");
        const noExhortoHidden = document.getElementById("NoExhortoHidden");
        const destinatario = document.getElementById("Destinatario");
        const bloqueOtro = document.getElementById("bloqueOtro");
        const otro = document.getElementById("Otro");
        const btnAgregar = document.getElementById("btnAgregarDiligencia");
        const tbody = document.querySelector("#tablaDiligencias tbody");
        const contenedorHidden = document.getElementById("contenedorHiddenDiligencias");
        const mensajeDiligencias = document.getElementById("mensajeDiligencias");

        let diligencias = [];
        let enviandoFormulario = false;

        function convertirMayusculas(texto) {
            return (texto || "").trim().toUpperCase();
        }

        function escaparHtml(texto) {
            return (texto || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#39;");
        }

        function limpiarValidacionesCaptura() {
            noExhorto.classList.remove("is-invalid");
            tipoDiligencia.classList.remove("is-invalid");
            destinatario.classList.remove("is-invalid");
            otro.classList.remove("is-invalid");
        }

        function limpiarCampos() {
            tipoDiligencia.value = "";
            destinatario.value = "";
            otro.value = "";

            bloqueOtro.classList.add("d-none");
            otro.required = false;

            limpiarValidacionesCaptura();
        }

        function limpiarTodoFormulario() {
            diligencias = [];
            tbody.innerHTML = "";
            contenedorHidden.innerHTML = "";
            mensajeDiligencias.classList.add("d-none");

            noExhorto.value = "";
            noExhortoHidden.value = "";

            tipoDiligencia.value = "";
            destinatario.value = "";
            otro.value = "";

            bloqueOtro.classList.add("d-none");
            otro.required = false;

            limpiarValidacionesCaptura();
        }

        tipoDiligencia.addEventListener("change", function () {
            const texto = this.options[this.selectedIndex].text.trim().toUpperCase();

            bloqueOtro.classList.add("d-none");
            otro.value = "";
            otro.required = false;
            otro.classList.remove("is-invalid");

            if (texto === "OTRA") {
                bloqueOtro.classList.remove("d-none");
                otro.required = true;
            }
        });

        btnAgregar.addEventListener("click", function () {
            limpiarValidacionesCaptura();

            const noExhortoValor = convertirMayusculas(noExhorto.value);
            const tipoId = tipoDiligencia.value;
            const tipoTexto = tipoDiligencia.options[tipoDiligencia.selectedIndex].text.trim().toUpperCase();
            const destinatarioValor = convertirMayusculas(destinatario.value);
            const otroValor = convertirMayusculas(otro.value);

            noExhorto.value = noExhortoValor;
            noExhortoHidden.value = noExhortoValor;
            destinatario.value = destinatarioValor;
            otro.value = otroValor;

            let formularioValido = true;

            if (noExhortoValor === "") {
                noExhorto.classList.add("is-invalid");
                formularioValido = false;
            }

            if (tipoId === "") {
                tipoDiligencia.classList.add("is-invalid");
                formularioValido = false;
            }

            if (destinatarioValor === "") {
                destinatario.classList.add("is-invalid");
                formularioValido = false;
            }

            if (tipoTexto === "OTRA" && otroValor === "") {
                otro.classList.add("is-invalid");
                formularioValido = false;
            }

            if (!formularioValido) {
                return;
            }

            const item = {
                NoExhorto: noExhortoValor,
                TipoDiligenciaId: tipoId,
                TipoDiligenciaDesc: tipoTexto,
                Destinatario: destinatarioValor,
                Otro: otroValor
            };

            diligencias.push(item);

            renderTabla();
            limpiarCampos();
            mensajeDiligencias.classList.add("d-none");
        });

        function renderTabla() {
            tbody.innerHTML = "";
            contenedorHidden.innerHTML = "";

            if (diligencias.length > 0) {
                noExhortoHidden.value = diligencias[0].NoExhorto;
            }

            diligencias.forEach((d, index) => {
                const fila = document.createElement("tr");

                fila.innerHTML = `
                    <td>${escaparHtml(d.NoExhorto)}</td>
                    <td>${escaparHtml(d.TipoDiligenciaDesc)}</td>
                    <td>${escaparHtml(d.Destinatario)}</td>
                    <td>${escaparHtml(d.Otro || "")}</td>
                    <td>
                        <button type="button" class="btn btn-danger btn-sm" onclick="eliminarDiligencia(${index})">
                            Eliminar
                        </button>
                    </td>
                `;

                tbody.appendChild(fila);

                contenedorHidden.innerHTML += `
                    <input type="hidden" name="Diligencias[${index}].NoExhorto" value="${escaparHtml(d.NoExhorto)}" />
                    <input type="hidden" name="Diligencias[${index}].TipoDiligenciaId" value="${escaparHtml(d.TipoDiligenciaId)}" />
                    <input type="hidden" name="Diligencias[${index}].TipoDiligenciaDesc" value="${escaparHtml(d.TipoDiligenciaDesc)}" />
                    <input type="hidden" name="Diligencias[${index}].Destinatario" value="${escaparHtml(d.Destinatario)}" />
                    <input type="hidden" name="Diligencias[${index}].Otro" value="${escaparHtml(d.Otro || "")}" />
                `;
            });
        }

        function eliminarDiligencia(index) {
            diligencias.splice(index, 1);
            renderTabla();

            if (diligencias.length === 0) {
                mensajeDiligencias.classList.remove("d-none");
                noExhortoHidden.value = "";
            }
        }

        formDiligencias.addEventListener("submit", function (event) {
            if (enviandoFormulario) {
                return;
            }

            const inputsTexto = formDiligencias.querySelectorAll("input[type='text']");
            inputsTexto.forEach(input => {
                input.value = input.value.toUpperCase();
            });

            if (diligencias.length === 0) {
                event.preventDefault();
                mensajeDiligencias.classList.remove("d-none");
                return;
            }

            const noExhortoValor = diligencias.length > 0
                ? diligencias[0].NoExhorto
                : convertirMayusculas(noExhorto.value);

            noExhorto.value = noExhortoValor;
            noExhortoHidden.value = noExhortoValor;
            mensajeDiligencias.classList.add("d-none");

            event.preventDefault();

            const toastElement = document.getElementById("toastDiligenciaGuardada");
            const toast = new bootstrap.Toast(toastElement);
            toast.show();

            enviandoFormulario = true;

            setTimeout(() => {
                formDiligencias.submit();
            }, 1200);
        });

        formDiligencias.addEventListener("reset", function () {
            setTimeout(() => {
                limpiarTodoFormulario();
            }, 0);
        });

        window.eliminarDiligencia = eliminarDiligencia;
    </script>
}