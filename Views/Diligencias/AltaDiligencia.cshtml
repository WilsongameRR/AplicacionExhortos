@model AplicacionExhortos.Models.AltaDiligenciasModel
@using AplicacionExhortos.Models

@{
    ViewData["Title"] = "Alta de Diligencia";
    bool bloqueado = TempData["BloquearDiligencias"] != null;
}

<div class="container-fluid fondo-exhortos min-vh-100 pb-5" style="padding-top:40px;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="text-center mt-4 mb-4">
                <h2>ALTA DE DILIGENCIAS</h2>
            </div>

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert">
                    <strong>@TempData["MensajeExito"]</strong><br />
                    Número de exhorto generado:
                    <strong>@TempData["NumeroExhorto"]</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorDiligencias"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show text-center mt-3" role="alert">
                    @TempData["ErrorDiligencias"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ExitoEnvio"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert">
                    @TempData["ExitoEnvio"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show text-center mt-3" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert">
                    @TempData["Exito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="col-12 text-start mt-2">
                <small class="text-muted">
                    Los campos marcados con <span class="text-danger">*</span> son obligatorios.
                </small>
            </div>

            <form id="formDiligencias"
                  method="post"
                  asp-controller="Diligencias"
                  asp-action="GuardarDiligencias"
                  novalidate>
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="NoExhorto" id="NoExhortoHidden" />

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">
                            <span class="required">*</span> No. de Exhorto
                        </label>
                        <input type="text"
                               asp-for="NoExhorto"
                               class="form-control text-uppercase"
                               id="NoExhorto"
                               maxlength="200"
                               readonly="@bloqueado" />
                        <div class="invalid-feedback">
                            Capture el número de exhorto.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">
                            <span class="required">*</span> Tipo diligencia
                        </label>
                        <select class="form-select" id="TipoDiligenciaId" disabled="@bloqueado">
                            <option value="">Seleccione...</option>
                            <option value="1">CITAR</option>
                            <option value="2">EMPLAZAR</option>
                            <option value="3">NOTIFICAR</option>
                            <option value="4">OTRA</option>
                        </select>
                        <div class="invalid-feedback">
                            Seleccione un tipo de diligencia.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">
                            <span class="required">*</span> Destinatario
                        </label>
                        <input type="text"
                               class="form-control text-uppercase"
                               id="Destinatario"
                               maxlength="200"
                               readonly="@bloqueado" />
                        <div class="invalid-feedback">
                            Capture el destinatario.
                        </div>
                    </div>

                    <div class="col-md-4 d-none" id="bloqueOtro">
                        <label class="form-label">
                            <span class="required">*</span> Especifique diligencia
                        </label>
                        <input type="text"
                               class="form-control text-uppercase"
                               id="Otro"
                               maxlength="80"
                               readonly="@bloqueado" />
                        <div class="invalid-feedback">
                            Especifique la diligencia.
                        </div>
                    </div>

                    @if (!bloqueado)
                    {
                        <div class="col-12 text-center mt-3">
                            <button type="button" id="btnAgregarDiligencia" class="btn btn-tua">
                                Agregar
                            </button>
                        </div>
                    }

                </div>

                <hr class="my-4" />

                <div class="mt-3">
                    <h4 class="text-center mb-3">DILIGENCIAS AGREGADAS</h4>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="tablaDiligencias">
                            <thead>
                                <tr>
                                    <th>No. Exhorto</th>
                                    <th>Tipo diligencia</th>
                                    <th>Destinatario</th>
                                    <th>Otro</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div id="contenedorHiddenDiligencias"></div>

                <div id="mensajeDiligencias" class="text-danger text-center mt-2 d-none">
                    Debe agregar al menos una diligencia antes de guardar.
                </div>

                @if (!bloqueado)
                {
                    <div class="col-12 text-center mt-4" id="panelGuardarDiligencias">
                        <button type="submit" id="btnGuardarDili" class="btn btn-tua me-2">
                            Guardar Diligencias
                        </button>

                        <button type="button" id="btnCancelarDili" class="btn btn-secondary">
                            Cancelar
                        </button>
                    </div>
                }
            </form>

        </div>
    </div>
</div>

<!-- MODAL CONFIRMAR SALIDA -->
<div class="modal fade" id="modalConfirmarSalida" tabindex="-1" aria-labelledby="modalConfirmarSalidaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header" style="background-color:#E87A45; color:white;">
                <h5 class="modal-title fw-bold">Confirmación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                Si sale de la pantalla, el Exhorto quedará registrado como <strong>No enviado</strong>.
                <br /><br />
                ¿Desea continuar?
            </div>

            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="button" id="btnConfirmarSalida" class="btn btn-danger">
                    Salir
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const $ = (id) => document.getElementById(id);

            const bloqueado = @Html.Raw(bloqueado.ToString().ToLower());

            const formDiligencias = $("formDiligencias");
            const tipoDiligencia = $("TipoDiligenciaId");
            const noExhorto = $("NoExhorto");
            const noExhortoHidden = $("NoExhortoHidden");
            const destinatario = $("Destinatario");
            const bloqueOtro = $("bloqueOtro");
            const otro = $("Otro");
            const btnAgregar = $("btnAgregarDiligencia");
            const btnCancelarDili = $("btnCancelarDili");
            const tbody = document.querySelector("#tablaDiligencias tbody");
            const contenedorHidden = $("contenedorHiddenDiligencias");
            const mensajeDiligencias = $("mensajeDiligencias");

            let diligencias = [];
            let enviandoFormulario = false;

            const upper = (valor) => (valor || "").trim().toUpperCase();

            const escapeHtml = (texto) =>
                (texto || "")
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll('"', "&quot;")
                    .replaceAll("'", "&#39;");

            const toggle = (elemento, mostrar) => {
                elemento.classList.toggle("d-none", !mostrar);
            };

            const limpiarInvalidos = () => {
                [noExhorto, tipoDiligencia, destinatario, otro].forEach(campo => {
                    if (campo) campo.classList.remove("is-invalid");
                });
            };

            const limpiarCaptura = () => {
                if (bloqueado) return;

                tipoDiligencia.value = "";
                destinatario.value = "";
                otro.value = "";
                otro.required = false;
                toggle(bloqueOtro, false);
                limpiarInvalidos();
            };

            const resetFormularioCompleto = () => {
                if (bloqueado) return;

                diligencias = [];
                tbody.innerHTML = "";
                contenedorHidden.innerHTML = "";
                mensajeDiligencias.classList.add("d-none");

                noExhorto.value = "";
                noExhortoHidden.value = "";

                limpiarCaptura();
            };

            const obtenerTextoTipo = () =>
                tipoDiligencia.options[tipoDiligencia.selectedIndex]?.text?.trim().toUpperCase() || "";

            const validarCaptura = () => {
                limpiarInvalidos();

                const numero = upper(noExhorto.value);
                const tipoId = tipoDiligencia.value;
                const tipoTexto = obtenerTextoTipo();
                const destinatarioValor = upper(destinatario.value);
                const otroValor = upper(otro.value);

                let esValido = true;

                if (!numero) {
                    noExhorto.classList.add("is-invalid");
                    esValido = false;
                }

                if (!tipoId) {
                    tipoDiligencia.classList.add("is-invalid");
                    esValido = false;
                }

                if (!destinatarioValor) {
                    destinatario.classList.add("is-invalid");
                    esValido = false;
                }

                if (tipoTexto === "OTRA" && !otroValor) {
                    otro.classList.add("is-invalid");
                    esValido = false;
                }

                return esValido;
            };

            const obtenerDiligenciaActual = () => {
                const numero = upper(noExhorto.value);
                const tipoId = tipoDiligencia.value;
                const tipoTexto = obtenerTextoTipo();
                const destinatarioValor = upper(destinatario.value);
                const otroValor = upper(otro.value);

                noExhorto.value = numero;
                noExhortoHidden.value = numero;
                destinatario.value = destinatarioValor;
                otro.value = otroValor;

                return {
                    NoExhorto: numero,
                    TipoDiligenciaId: tipoId,
                    TipoDiligenciaDesc: tipoTexto,
                    Destinatario: destinatarioValor,
                    Otro: otroValor
                };
            };

            const construirHiddenInputs = (d, index) => `
                <input type="hidden" name="Diligencias[${index}].NoExhorto" value="${escapeHtml(d.NoExhorto)}" />
                <input type="hidden" name="Diligencias[${index}].TipoDiligenciaId" value="${escapeHtml(d.TipoDiligenciaId)}" />
                <input type="hidden" name="Diligencias[${index}].TipoDiligenciaDesc" value="${escapeHtml(d.TipoDiligenciaDesc)}" />
                <input type="hidden" name="Diligencias[${index}].Destinatario" value="${escapeHtml(d.Destinatario)}" />
                <input type="hidden" name="Diligencias[${index}].OtraEspecificar" value="${escapeHtml(d.Otro || "")}" />
            `;

            const construirFila = (d, index) => `
                <tr>
                    <td>${escapeHtml(d.NoExhorto)}</td>
                    <td>${escapeHtml(d.TipoDiligenciaDesc)}</td>
                    <td>${escapeHtml(d.Destinatario)}</td>
                    <td>${escapeHtml(d.Otro || "")}</td>
                    <td>
                        ${bloqueado ? "" : `
                            <button type="button" class="btn btn-danger btn-sm" onclick="eliminarDiligencia(${index})">
                                Eliminar
                            </button>
                        `}
                    </td>
                </tr>
            `;

            const renderTabla = () => {
                tbody.innerHTML = diligencias.map(construirFila).join("");
                contenedorHidden.innerHTML = diligencias.map(construirHiddenInputs).join("");

                noExhortoHidden.value = diligencias.length > 0 ? diligencias[0].NoExhorto : "";

                if (diligencias.length === 0) {
                    mensajeDiligencias.classList.remove("d-none");
                } else {
                    mensajeDiligencias.classList.add("d-none");
                }
            };

            const agregarDiligencia = () => {
                if (bloqueado) return;

                if (!validarCaptura()) {
                    return;
                }

                diligencias.push(obtenerDiligenciaActual());
                renderTabla();
                limpiarCaptura();
            };

            const eliminarDiligencia = (index) => {
                if (bloqueado) return;

                diligencias.splice(index, 1);
                renderTabla();
            };

            const prepararEnvioFormulario = (event) => {
                if (bloqueado) {
                    event.preventDefault();
                    return;
                }

                if (enviandoFormulario) {
                    return;
                }

                if (diligencias.length === 0) {
                    event.preventDefault();
                    mensajeDiligencias.classList.remove("d-none");
                    return;
                }

                const numero = diligencias[0].NoExhorto || upper(noExhorto.value);

                noExhorto.value = numero;
                noExhortoHidden.value = numero;

                formDiligencias
                    .querySelectorAll("input[type='text']")
                    .forEach(input => input.value = upper(input.value));

                enviandoFormulario = true;
            };

            tipoDiligencia?.addEventListener("change", () => {
                if (bloqueado) return;

                const esOtra = obtenerTextoTipo() === "OTRA";
                toggle(bloqueOtro, esOtra);
                otro.required = esOtra;

                if (!esOtra) {
                    otro.value = "";
                    otro.classList.remove("is-invalid");
                }
            });

            btnAgregar?.addEventListener("click", agregarDiligencia);

            formDiligencias?.addEventListener("submit", prepararEnvioFormulario);

                           const modalConfirmar = new bootstrap.Modal(document.getElementById('modalConfirmarSalida'));

        btnCancelarDili?.addEventListener("click", () => {
            modalConfirmar.show();
        });

        document.getElementById("btnConfirmarSalida")?.addEventListener("click", () => {
            window.location.href = '@Url.Action("AltaDeExhortos", "Exhortos")';
        });

            window.eliminarDiligencia = eliminarDiligencia;
        })();

        setTimeout(function () {
            let alerts = document.querySelectorAll(".alert");

            alerts.forEach(function (alert) {
                alert.style.transition = "opacity 0.5s ease, transform 0.5s ease";
                alert.style.opacity = "0";
                alert.style.transform = "translateY(-10px)";

                setTimeout(() => alert.remove(), 500);
            });
        }, 3000);
    </script>
}